NEXT_PUBLIC_API_URL=http://localhost:8000/api
# Server-side target for Next.js /api rewrites. On Vercel, set this to the
# deployed backend. Browser requests and server-rendered public pages both use
# this target so the admin and public website always read the same database.
API_PROXY_TARGET=http://localhost:8000
# Optional server-side fallback when API_PROXY_TARGET is not set. It must point
# to the same backend API and include the /api suffix.
# INTERNAL_API_URL=http://localhost:8000/api
